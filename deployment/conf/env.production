# ==============================================================================
# CLM Enterprise — Production Environment Variables
# Copy to: /opt/clm/app/apps/backend/.env
#
# Values marked <GENERATE> are auto-filled by 07-app-deploy.sh
# Values marked <FILL_IN> must be manually provided
# ==============================================================================

# ── 1. CORE ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://clm.rpsg.in
CORS_ORIGINS=https://clm.rpsg.in

# ── 2. DATABASE (auto-filled from PostgreSQL setup) ──────────────────────────
DATABASE_URL="postgresql://clmuser:<GENERATE>@localhost:5432/clm?schema=public&connection_limit=20"

# ── 3. REDIS (auto-filled from Redis setup) ──────────────────────────────────
REDIS_URL="redis://:<GENERATE>@127.0.0.1:6379"

# ── 4. JWT AUTHENTICATION (auto-generated) ──────────────────────────────────
JWT_SECRET=<GENERATE>
JWT_REFRESH_SECRET=<GENERATE>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 5. AWS S3 STORAGE (existing — fill in your credentials) ─────────────────
AWS_ACCESS_KEY_ID=<FILL_IN>
AWS_SECRET_ACCESS_KEY=<FILL_IN>
AWS_REGION=ap-south-1
S3_BUCKET_NAME=<FILL_IN>
S3_FORCE_PATH_STYLE=false

# ── 6. EMAIL — Microsoft 365 (already configured) ───────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<FILL_IN>
SMTP_PASS=<FILL_IN>
EMAIL_FROM=<FILL_IN>
EMAIL_FROM_NAME="LUMINA CLM"

# ── 7. NOTIFICATIONS ────────────────────────────────────────────────────────
LEGAL_APPROVER_EMAIL=legal@rpsg.in
FINANCE_APPROVER_EMAIL=finance@rpsg.in

# ── 8. AI / GEMINI (optional) ───────────────────────────────────────────────
AI_MODEL_NAME=gemini-1.5-pro
AI_API_KEY=
VERTEXT_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# ── 9. SENTRY (optional) ────────────────────────────────────────────────────
SENTRY_DSN=

# ── 10. SWAGGER (optional — enable for debugging) ───────────────────────────
ENABLE_SWAGGER=false
