# ==============================================================================
# CLM Enterprise — Production Environment Variables
# Copy to: /opt/clm/app/apps/backend/.env
#
# Values marked _GENERATE_ are auto-filled by 07-app-deploy.sh
# Values marked _FILL_IN_ must be manually provided
# ==============================================================================

# ── 1. CORE ──────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="3001"
FRONTEND_URL="https://clm.rpsg.in"
CORS_ORIGINS="https://clm.rpsg.in"

# ── 2. DATABASE (auto-filled from PostgreSQL setup) ──────────────────────────
DATABASE_URL="postgresql://clmuser:_GENERATE_@localhost:5432/clm?schema=public&connection_limit=20"

# ── 3. REDIS (auto-filled from Redis setup) ──────────────────────────────────
REDIS_URL="redis://:_GENERATE_@127.0.0.1:6379"

# ── 4. JWT AUTHENTICATION (auto-generated) ──────────────────────────────────
JWT_SECRET="_GENERATE_"
JWT_REFRESH_SECRET="_GENERATE_"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── 5. AWS S3 STORAGE (existing — fill in your credentials) ─────────────────
AWS_ACCESS_KEY_ID="_FILL_IN_"
AWS_SECRET_ACCESS_KEY="_FILL_IN_"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="_FILL_IN_"
S3_FORCE_PATH_STYLE="false"

# ── 6. EMAIL — Microsoft 365 (already configured) ───────────────────────────
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="_FILL_IN_"
SMTP_PASS="_FILL_IN_"
EMAIL_FROM="_FILL_IN_"
EMAIL_FROM_NAME="LUMINA CLM"
EMAIL_PROVIDER=graph

# ── 7. NOTIFICATIONS ────────────────────────────────────────────────────────
LEGAL_APPROVER_EMAIL="legal@rpsg.in"
FINANCE_APPROVER_EMAIL="finance@rpsg.in"

# ── 8. AI / GEMINI (optional) ───────────────────────────────────────────────
GEMINI_API_KEY="_FILL_IN_"
OPENAI_API_KEY="_FILL_IN_"
AI_MODEL_NAME="gemini-1.5-pro"
VERTEXT_AI_PROJECT_ID=""
VERTEX_AI_LOCATION="us-central1"

# ── 9. SENTRY (optional) ────────────────────────────────────────────────────
SENTRY_DSN=""

# ── 10. SWAGGER (optional — enable for debugging) ───────────────────────────
ENABLE_SWAGGER="false"

# --- Microsoft Graph API Configuration (if EMAIL_PROVIDER=graph) ---
# Requires Azure AD App Registration with Mail.Send permission
MS_GRAPH_TENANT_ID="_FILL_IN_"
MS_GRAPH_CLIENT_ID="_FILL_IN_"
MS_GRAPH_CLIENT_SECRET="_FILL_IN_"
